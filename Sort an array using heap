class Solution {
    public int[] sortArray(int[] nums) {
        PriorityQueue<Integer> minHeap = new PriorityQueue<>();

        for(int num : nums){
            minHeap.add(num);
        }

        int[] result = new int[nums.length];
        for(int i=0; i<nums.length; i++){
            result[i] = minHeap.poll();
        }

        return result;
    }
}
